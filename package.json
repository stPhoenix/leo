{
  "name": "leo",
  "version": "0.0.1",
  "description": "Local-first Obsidian chat, RAG, and agent plugin.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:llm": "vitest run --config vitest.llm.config.ts",
    "bench": "vitest bench --run",
    "smoke": "vitest run tests/smoke",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"*.{json,md,mjs,cjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"*.{json,md,mjs,cjs}\""
  },
  "keywords": [
    "obsidian-plugin",
    "rag",
    "agent",
    "langgraph"
  ],
  "author": "Leo",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^14.3.1",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.4",
    "obsidian": "^1.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "minimatch": "^10.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
